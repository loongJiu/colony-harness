{
  "name": "@colony-harness/llm-openai-compatible",
  "version": "1.1.1",
  "description": "OpenAI-compatible provider for any OpenAI API compatible endpoint",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@colony-harness/llm-openai": "workspace:*"
  }
}
