{
  "name": "colony-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready AI agent harness built on colony-bee-sdk concepts",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean",
    "dev": "turbo run dev --parallel",
    "docs:dev": "vitepress dev docs --host 0.0.0.0 --port 5173",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 0.0.0.0 --port 4173",
    "release": "node scripts/release.mjs",
    "release:dry-run": "node scripts/release.mjs --dry-run",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.4"
  }
}
